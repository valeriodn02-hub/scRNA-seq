install.packages("Seurat")


library(BPCells)
library(Seurat)
library(SeuratObject)

# Supponiamo che tu riparta da dopo NormalizeData/FindVariableFeatures
# ma prima di ScaleData/RunPCA

# 1. Scrivi la matrice counts su disco in formato BPCells
write_matrix_dir(
  mat = seu_pulito_full[["RNA"]]$counts,
  dir = "bpcells_counts"   # cartella dove salvare i dati on-disk
)

# 2. Ricarica la matrice come oggetto BPCells (puntatore ai file su disco)
counts_mat <- open_matrix_dir(dir = "bpcells_counts")
# Converte la matrice in formato interi compressi, più efficiente
counts_mat <- convert_matrix_type(counts_mat, type = "uint32_t")  # o il tipo intero raccomandato da BPCells

# 3. Sostituisci il layer counts nell'assay con la versione on-disk
seu_pulito_full[["RNA"]]$counts <- counts_mat


#CheckPoint
saveRDS(seu_pulito_full, file = "seu_pulito_full_checkpoint.rds")
        
seu_pulito_full <- readRDS(file = "seu_pulito_full_checkpoint.rds" )

write_matrix_dir(
  mat = seu_pulito_full[["RNA"]]$data, 
  dir = "bpcells_data"
  )
data_mat <- open_matrix_dir(dir = "bpcells_data")
seu_pulito_full[["RNA"]]$data <- data_mat

gc()



################################################### fine

seu_pulito_full <- RunPCA(seu_pulito_full)

# Determine percent of variation associated with each PC(https://hbctraining.github.io/scRNA-seq/lessons/elbow_plot_metric.html)
# use PCA reduction
pct <- seu_pulito_full[["pca"]]@stdev / sum(seu_pulito_full[["pca"]]@stdev) * 100

# Calculate cumulative percents for each PC
cumu <- cumsum(pct)

# Determine which PC exhibits cumulative percent greater than 90% and % variation associated with the PC as less than 5
co1 <- which(cumu > 90 & pct < 5)[1]

co1
#42

# Determine the difference between variation of PC and subsequent PC
co2 <- sort(which((pct[1:length(pct) - 1] - pct[2:length(pct)]) > 0.1), decreasing = T)[1] + 1

# last point where change of % of variation is more than 0.1%.
co2
#15
# Minimum of the two calculation
pcs <- min(co1, co2)

pcs # 15

options(future.globals.maxSize = 100000 * 1024^2)
seu_pulito_full <- FindNeighbors(seu_pulito_full, dims = 1:14, reduction = "pca")
seu_pulito_full <- FindClusters(seu_pulito_full, cluster.name = "unintegrated_clusters")
seu_pulito_full <- RunUMAP(seu_pulito_full, dims = 1:14, reduction = "pca", reduction.name = "umap.unintegrated")

grafico_cell_type<- DimPlot(seu_pulito_full, reduction = "umap.unintegrated",label = T, group.by = c("Cell_Type"))

grafico_dataset<- DimPlot(seu_pulito_full, reduction = "umap.unintegrated", group.by = c("Dataset"))

ggsave("grafici/umap_cell_type.png", plot = grafico_cell_type, width = 8, height = 6, dpi = 300)
ggsave("grafici/umap_dataset.png", plot = grafico_dataset, width = 8, height = 6, dpi = 300)

saveRDS(seu_pulito_full, file = "seu_pulito_full.rds")
@

<<Rimozione batch effect>>=
seu_pulito_full <- readRDS("seu_pulito_full.rds")

#### perform integration ####

install.packages("harmony")
library(harmony)
library(Seurat)
library(SeuratObject)



#Da Seurat v5 in poi, un assay può invece contenere più "copie" parallele dello stesso tipo di dato, chiamate layer, una per ciascun sottoinsieme (tipicamente uno per campione/dataset). Quindi invece di un'unica matrice counts, puoi avere counts.GSE134520, counts.GSE150290, counts.GSE163558, ecc. — ognuna contenente solo le cellule di quel dataset specifico, ma tutte "vivendo" dentro lo stesso oggetto Seurat.
seu_pulito_full[["RNA"]] <- split(seu_pulito_full[["RNA"]], f = 
                                    seu_pulito_full$Dataset)
seu_pulito_full <- IntegrateLayers(
  object = seu_pulito_full, 
  method = HarmonyIntegration,
  orig.reduction = "pca", 
  new.reduction = "harmony",
  verbose = TRUE)

# re-join layers after integration
seu_pulito_full <- JoinLayers(seu_pulito_full)

#### Perform the standard workflow for clustering analysis of the integrated dataset ####
seu_pulito_full@reductions$harmony@stdev = as.numeric(apply(seu_pulito_full@reductions$harmony@cell.embeddings, 2, stats::sd))

# Determine percent of variation associated with each PC(https://hbctraining.github.io/scRNA-seq/lessons/elbow_plot_metric.html)
# use harmony reduction
pct_har <- seu_pulito_full[["harmony"]]@stdev / sum(seu_pulito_full[["harmony"]]@stdev) * 100

# Calculate cumulative percents for each PC
cumu_har <- cumsum(pct_har)

# Determine which PC exhibits cumulative percent greater than 90% and % variation associated with the PC as less than 5
co1_har <- which(cumu_har > 90 & pct_har < 5)[1]

co1_har
#42

# Determine the difference between variation of PC and subsequent PC
co2_har <- sort(which((pct_har[1:length(pct_har) - 1] - pct_har[2:length(pct_har)]) > 0.1), decreasing = T)[1] + 1

# last point where change of % of variation is more than 0.1%.
co2_har
#25
# Minimum of the two calculation
pcs_har <- min(co1_har, co2_har)

pcs_har # 25

seu_pulito_full <- FindNeighbors(seu_pulito_full, reduction = "harmony", dims = 1:25)
seu_pulito_full <- FindClusters(seu_pulito_full, resolution = c(0.25, 0.5, 0.75, 1,1.25))
seu_pulito_full <- RunUMAP(seu_pulito_full, dims = 1:25, reduction = "harmony",reduction.name = "umap.harmony")

#grafico_pulito_cell_type<- DimPlot(seu_pulito_full, reduction = "umap.harmony",label = T, group.by = c("Cell_Type"))

#grafico_pulito_dataset<- DimPlot(seu_pulito_full, reduction = "umap.harmony", group.by = c("Dataset"))

#ggsave("grafici/umap_puliti_cell_type.png", plot = grafico_pulito_cell_type, width = 8, height = 6, dpi = 300)
#ggsave("grafici/umap_puliti_dataset.png", plot = grafico_pulito_dataset, width = 8, height = 6, dpi = 300)

saveRDS(seu_pulito_full, file = "Gastric_integrated_data.rds")

