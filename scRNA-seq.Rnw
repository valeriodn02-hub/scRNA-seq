# SALVAGENTE: Creiamo il checkpoint!
# Se il PC dovesse crashare in futuro, ripartirai direttamente da qui.
saveRDS(seu_obj1.1, file = "seu_obj1.1.rds")

rm(seu_qc_ready)
gc()

