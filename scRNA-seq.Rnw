set.seed(42)


# 2. Usiamo DietSeurat per mantenere SOLO l'assay RNA e i raw counts
# Mettiamo scale.data = FALSE, dimreducs = NULL, e graphs = NULL
# Questo butterà via UMAP, PCA, normalizzazioni e tutto il resto, 
# lasciando un oggetto pulito senza causare picchi di RAM
seu_qc_ready <- DietSeurat(seu_obj, 
                           assays = "RNA", 
                           counts = TRUE,      # Teniamo i raw counts
                           data = FALSE,       # Buttiamo i dati normalizzati
                           scale.data = FALSE, # Buttiamo i dati scalati
                           dimreducs = NULL,   # Buttiamo PCA, UMAP, ecc.
                           graphs = NULL)      # Buttiamo i grafi di clustering

# Controllo
seu_qc_ready
#An object of class Seurat 
#39058 features across 574532 samples within 1 assay 
#Active assay: RNA (39058 features, 0 variable features)
#1 layer present: counts

rm(seu_obj)
table(seu_qc_ready@meta.data$Phenotype_factor)

seu_obj1.1 <-  subset(seu_qc_ready, subset= Phenotype_factor %in% c("Normal", "ADJ_GC", "GC"))
table(seu_obj1.1@meta.data$Phenotype_factor)
