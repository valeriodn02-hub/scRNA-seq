<<QC>>=
library(tidyverse)
library(pheatmap)
library(patchwork)


seu_obj1<- seu_obj1.1
rm(seu_obj1.1)

# 1. Impostiamo l'identità attiva (serve per sicurezza)
Idents(seu_obj1) <- "Dataset"

seu_obj1@assays$RNA$counts[1:2, 1:2]
# 2 x 2 sparse Matrix of class "dgCMatrix"
#            GSE134520_AAACCTGAGCGGATCA.1 GSE134520_AAACCTGCAGTGAGTG.1
# AL627309.1                            .                            .
# AP006222.2                            .                            .

# Calcolo percentuale mitocondriale
# This function enables you to easily calculate the percentage of all the counts belonging to a subset of the possible features for each cell. This is useful when trying to compute the percentage of transcripts that map to mitochondrial genes for example. 
seu_obj1$percent.mt <- PercentageFeatureSet(object = seu_obj1, pattern = '^MT-')

#Decido che soglia usare
VlnPlot(object = seu_obj1, features = c("nFeature_RNA", "nCount_RNA", "percent.mt", "percent_hb"), ncol = 4, pt.size = 0)
FeatureScatter(seu_obj1, feature1 = "nCount_RNA", feature2 = "nFeature_RNA")


# Prendo i nomi dei geni mitocondriali (validi per tutto l'oggetto)
mt_genes <- grep('^MT-', rownames(seu_obj1), value = TRUE)
mt_genes

# Sottoinsieme di sole cellule GSE225275
# WhichCells Returns a list of cells that match a particular set of criteria such as identity class, high/low values for particular PCs, etc
cells_225275 <- WhichCells(seu_obj1, expression = Dataset == "GSE225275")

# Guardo se i conteggi grezzi su quei geni sono tutti zero SOLO per queste cellule
# GetAssayData can be used to pull information from any of the expression matrices (eg. “counts”, “data”, or “scale.data”). SetAssayData can be used to replace one of these expression matrices
counts_225275 <- GetAssayData(seu_obj1, layer = "counts")[mt_genes, cells_225275]
summary(rowSums(counts_225275))
# Min. 1st Qu.  Median    Mean 3rd Qu.    Max. 
#       0       0       0    1256       0   38926
range(counts_225275)
# > range(counts_225275)
# [1]  0 54

# Confronto con un dataset che ha percent.mt normale, es. GSE134520
cells_134520 <- WhichCells(seu_obj1, expression = Dataset == "GSE134520")
counts_134520 <- GetAssayData(seu_obj1, layer = "counts")[mt_genes, cells_134520]
summary(rowSums(counts_134520))
  # Min. 1st Qu.  Median    Mean 3rd Qu.    Max. 
  #     0       0       0  360928  500940 2410163
range(counts_134520)
# > range(counts_134520)
# [1]    0 1018

# Applico i filtri definiti
seu_pulito_full <- subset(seu_obj1, 
                          subset = nFeature_RNA > 200 & 
                                   nFeature_RNA < 5000 &
                                   percent.mt < 15 &
                                  percent_hb < 5)

# Verifico quante cellule sono rimaste
cat("Cellule dopo il filtro:", ncol(seu_pulito_full), "\n")
# Cellule dopo il filtro: 353246 
cat("Percentuale mantenuta:", round(100 * ncol(seu_pulito_full) / ncol(seu_obj1), 2), "%\n")
# Percentuale mantenuta: 93.22 %

# Re-ispeziono i violini dopo la pulizia
violinplot_dati_filtrati <- VlnPlot(object = seu_pulito_full, features = c("nFeature_RNA", "nCount_RNA", "percent.mt", "percent_hb"), ncol = 4, pt.size = 0)

#Controllo se è presente un determinato dataset che non visualizzo nel violinplot
table(seu_pulito_full@active.ident)
table(seu_pulito_full$Phenotype_factor[seu_pulito_full$Dataset == "GSE228598"])
